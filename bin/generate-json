#!/usr/bin/env python3
import json
import re
import sys
from datetime import datetime
from pathlib import Path

README = Path(__file__).parent.parent / "README.md"
OUTPUT = Path(__file__).parent.parent / "fax.json"

HEADER = re.compile(r"^### (.+)$")
INDENTED = re.compile(r"^    (.+)$")
MESSAGE = re.compile(r"^<([^>]+)> *(.*)")
ACTION = re.compile(r"^\*+ *(?:<([^>]+)>|(\S+)) *(.*)")
COMMENT = re.compile(r"^\((.+)\)$")
SOURCE = re.compile(r"^\(\[source\]\(([^)]+)\)\)$")


def parse_timestamp(header):
    try:
        return datetime.strptime(header, "%d %B %Y %H:%M UTC").strftime("%Y-%m-%dT%H:%M:%SZ")
    except ValueError:
        pass
    m = re.match(r"Sometime in (\w+) (\d{4})", header)
    if m:
        return datetime.strptime(f"1 {m.group(1)} {m.group(2)}", "%d %B %Y").strftime("%Y-%m-%dT00:00:00Z")
    raise ValueError(f"Unrecognised header: {header!r}")


def parse_line(line):
    if m := COMMENT.match(line):
        return {"type": "comment", "content": m.group(1)}
    if m := ACTION.match(line):
        nick = m.group(1) or m.group(2)
        return {"type": "action", "nick": nick, "content": m.group(3)}
    if m := MESSAGE.match(line):
        return {"type": "message", "nick": m.group(1), "content": m.group(2)}
    return None


quotes = []
current_at = None
current_lines = []
current_source = None


def flush():
    if current_at and current_lines:
        quote = {"at": current_at, "lines": current_lines}
        if current_source:
            quote["source"] = current_source
        quotes.append(quote)


for raw in README.read_text().splitlines():
    if m := HEADER.match(raw):
        flush()
        current_at = parse_timestamp(m.group(1))
        current_lines = []
        current_source = None
    elif m := SOURCE.match(raw):
        current_source = m.group(1)
    elif m := INDENTED.match(raw):
        if obj := parse_line(m.group(1)):
            current_lines.append(obj)

flush()

OUTPUT.write_text(json.dumps(quotes, indent=2, ensure_ascii=False) + "\n")
print(f"Written to {OUTPUT}")
